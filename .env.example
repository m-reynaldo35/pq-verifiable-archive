# Mainnet (production) — switch to testnet URLs for local dev if needed
ALGORAND_NODE_URL=https://mainnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://mainnet-idx.algonode.cloud

# Legacy aliases (still read by register-key.ts)
ALGONODE_ALGOD=https://mainnet-api.algonode.cloud
ALGONODE_INDEXER=https://mainnet-idx.algonode.cloud

# Generated by scripts/generate-wallet.ts
ALGORAND_MNEMONIC=

# Generated by scripts/register-key.ts — store public key here after registration
DOCUSIGN_MLDSA_PUBLIC_KEY=
DOCUSIGN_MLDSA_PRIVATE_KEY=
DOCUSIGN_KEY_REGISTRATION_TXN_ID=

# DocuSign sandbox (Phase 4)
DOCUSIGN_HMAC_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_PRIVATE_KEY=   # RSA private key PEM, base64-encoded
DOCUSIGN_SANDBOX=true

# When true, an inline base64 test PDF in the webhook body bypasses the DocuSign
# download so the pipeline can run without DocuSign credentials. Keep false in production.
DOCUSIGN_ALLOW_TEST_PDF=false
PORT=3000
